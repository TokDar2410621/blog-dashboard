# REQUIRED — Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Database URL (leave empty for default SQLite)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Pexels API key — https://www.pexels.com/api/
PEXELS_API_KEY=

# Google Gemini API key — https://aistudio.google.com/
GEMINI_API_KEY=

# Serper API key (for AI article search) — https://serper.dev/
SERPER_API_KEY=
